# Medusa Backend (запущенный локально или URL деплоя)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API Key — нужен для Store API (каталог, корзина).
# Взять в Admin: http://localhost:9000/app → Settings → Developer → Publishable API Keys (скопировать токен).
# Токен из: cd backend && npm run get-publishable-key
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
