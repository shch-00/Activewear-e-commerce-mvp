# PostgreSQL (обязательно)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa-store

# Redis (опционально, для production)
# REDIS_URL=redis://localhost:6379

# Секреты (можно сгенерировать: openssl rand -hex 32)
# JWT_SECRET=
# COOKIE_SECRET=

# CORS (для локальной разработки можно не задавать — в medusa-config есть значения по умолчанию)
# STORE_CORS=http://localhost:3000
# ADMIN_CORS=http://localhost:9000
# AUTH_CORS=http://localhost:9000
